# ─── Supabase ────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Supabase Storage Buckets ────────────────────────────────
# These must match the bucket names created via migration 005
NEXT_PUBLIC_SUPABASE_AUDIO_BUCKET=interview-audio
NEXT_PUBLIC_SUPABASE_TRANSCRIPT_BUCKET=interview-transcripts
NEXT_PUBLIC_SUPABASE_AVATAR_BUCKET=avatars

# ─── Google Gemini ───────────────────────────────────────────
# Found in: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key

# Gemini Flash Lite Live — real-time interview voice/text model
NEXT_PUBLIC_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Gemini Pro — post-session analysis model
GEMINI_ANALYSIS_MODEL=gemini-3.1-pro-preview

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
